{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://thecenterbookgr.com https://*.thecenterbookgr.com https://thecenterbook1.wpenginepowered.com"
        }
      ]
    }
  ]
}
