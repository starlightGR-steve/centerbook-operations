# CenterBook Operations — Environment Variables
# Copy this file to .env.local and fill in your values

# WordPress REST API (server-side only — used by Next.js API proxy at /api/cb/...)
# Production: https://thecenterbookgr.com/wp-json
# Staging:    https://thecenterbook1.wpenginepowered.com/wp-json
WP_API_URL=https://thecenterbook1.wpenginepowered.com/wp-json
WP_API_USER=
WP_API_PASSWORD=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
