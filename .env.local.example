# CenterBook Operations — Environment Variables
# Copy this file to .env.local and fill in your values

# WordPress REST API
# Production: https://thecenterbookgr.com/wp-json/cb/v1
# Staging:    https://thecenterbook1.wpenginepowered.com/wp-json/cb/v1
NEXT_PUBLIC_API_BASE=https://thecenterbook1.wpenginepowered.com/wp-json/cb/v1
NEXT_PUBLIC_API_USER=
NEXT_PUBLIC_API_PASS=

# Mock mode — set to "true" to use mock data instead of real API
# Useful for development when backend endpoints don't exist yet
NEXT_PUBLIC_USE_MOCK=true

# Per-module real API overrides (used when USE_MOCK=true)
# Set to "true" to use real API for a specific module while keeping others mocked
# NEXT_PUBLIC_ATTENDANCE_REAL=true
